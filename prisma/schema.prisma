generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Colaborador {
  id      Int    @id @default(autoincrement())
  nome    String
  cargo   String
  cpf     String @unique // CPF único para não repetir funcionários
  salario Float  // No Prisma, usamos Float ou Decimal para números com centavos
  
  pontos Ponto[] // Um colaborador tem muitos pontos

  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
}

model Ponto {
  id        Int      @id @default(autoincrement())
  cpf       String
  tipo      String
  dataHora  DateTime @default(now())

  // Criando a relação:
  colaborador   Colaborador @relation(fields: [cpf], references: [cpf], onDelete: Cascade)
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  password    String       // Aqui vai o hash da senha criptografada
  role        String       @default("USER") // Ex: "ADMIN", "SUPERVISOR", "USER"
  createdAt   DateTime     @default(now())
  
  colaborador Colaborador?
}